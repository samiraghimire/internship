☰
</label>


<nav class="menu">

<a href="#home">Home</a>
<a href="#dashboard">Dashboard</a>
<a href="#patients">Patients</a>
<a href="#doctors">Doctors</a>
<a href="#appointments">Appointments</a>
<a href="#contact">Contact</a>

